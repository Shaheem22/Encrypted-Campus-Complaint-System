# ============================================================
# ESCMS Environment Configuration
# ============================================================
# Copy this file to .env and update values for production.
# Not in production but remember to change in production.
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# Encryption (CHANGE IN PRODUCTION — must be 32+ chars)
ENCRYPTION_KEY=change-this-to-a-very-long-random-string-in-production

# Session (CHANGE IN PRODUCTION)
SESSION_SECRET=change-this-session-secret-in-production-use-random-string

# CORS — frontend origin
CORS_ORIGIN=http://localhost:5173

# Bcrypt salt rounds (12 minimum recommended)
BCRYPT_SALT_ROUNDS=12
